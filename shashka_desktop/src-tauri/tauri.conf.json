{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "shashka-ai",
  "version": "1.0.0",
  "identifier": "uz.dilshod.Шашки",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Шашки с ИИ",
        "width": 780,
        "height": 960,
        "minWidth": 380,
        "minHeight": 560,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["models/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
